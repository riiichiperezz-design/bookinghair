{
  "expo": {
    "name": "ecco",
    "slug": "ecco",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ecco",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#140805",
    "ios": {
      "bundleIdentifier": "com.ecco.app"
    },
    "android": {
      "package": "com.ecco.app",
      "adaptiveIcon": {
        "backgroundColor": "#140805",
        "foregroundImage": "./assets/images/adaptive-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-audio",
        {
          "microphonePermission": "ecco necesita el micrófono para grabar tus voces."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#E8602C"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#140805",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 140,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 140,
            "backgroundColor": "#140805"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
